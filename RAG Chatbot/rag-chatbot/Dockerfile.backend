# Dockerfile.backend
# Builds the FastAPI + LangChain + ChromaDB RAG backend service.

FROM python:3.11-slim

WORKDIR /app

# build-essential is needed for some chromadb/pypdf native wheels on slim images
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY backend/ .

# ChromaDB's on-disk persistence directory - mount a volume here in production
# so the vector store survives container restarts/redeploys.
VOLUME ["/app/chroma_store"]

EXPOSE 8000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
